#!/usr/bin/env python3
from __future__ import annotations

import argparse
import http.server
import socketserver
import subprocess

BUNDLED_VERSION = "0.1.0"


def gpu_util() -> str:
    cmd = [
        "nvidia-smi",
        "--query-gpu=utilization.gpu,uuid",
        "--format=csv,noheader,nounits",
    ]
    try:
        out = subprocess.check_output(cmd, text=True, timeout=5)
    except Exception:
        return "# HELP DCGM_FI_DEV_GPU_UTIL GPU utilization\n# TYPE DCGM_FI_DEV_GPU_UTIL gauge\n"

    lines = [
        "# HELP DCGM_FI_DEV_GPU_UTIL GPU utilization",
        "# TYPE DCGM_FI_DEV_GPU_UTIL gauge",
    ]
    for idx, row in enumerate(out.splitlines()):
        row = row.strip()
        if not row:
            continue
        parts = [p.strip() for p in row.split(",", 1)]
        util = parts[0]
        uuid = parts[1] if len(parts) > 1 else f"GPU-{idx}"
        lines.append(f'DCGM_FI_DEV_GPU_UTIL{{gpu="{idx}",UUID="{uuid}"}} {util}')
    return "\n".join(lines) + "\n"


class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self) -> None:
        if self.path != "/metrics":
            self.send_response(404)
            self.end_headers()
            return
        body = gpu_util().encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; version=0.0.4")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, *_args) -> None:
        return


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--web-listen-address", default=":9400")
    parser.add_argument("--version", action="store_true")
    args = parser.parse_args()
    if args.version:
        print(BUNDLED_VERSION)
        raise SystemExit(0)
    host, _, port = args.web_listen_address.rpartition(":")
    host = host or "0.0.0.0"
    with socketserver.TCPServer((host, int(port)), Handler) as httpd:
        httpd.serve_forever()
